# ============================================
# LootLink Marketplace — Environment Variables
# ============================================
# Скопируйте в .env и заполните значения
# cp env.example.txt .env

# Docker Compose (Windows / Docker Desktop)
# Если в контейнере ошибка «can't open file '/app/manage.py'» — задайте абсолютный путь
# к корню репозитория прямыми слешами и включите диск в Docker Desktop → Settings → Resources → File sharing.
# Альтернатива: запуск без правки .env — .\scripts\docker-compose-up.ps1 up -d
# PROJECT_ROOT=F:/LootLink---Marketplace

# Django Core
SECRET_KEY=your-secret-key-here-generate-with-django
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Database (PostgreSQL)
DB_NAME=lootlink
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Redis (для cache, channels, celery)
USE_REDIS=False
REDIS_URL=redis://localhost:6379/0

# Email (для отправки писем)
# Development: console (письма выводятся в терминал)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Production: раскомментируйте и заполните (см. docs/EMAIL_PRODUCTION_SETUP.md)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.yandex.ru
# EMAIL_PORT=465
# EMAIL_USE_TLS=False
# EMAIL_USE_SSL=True
# EMAIL_HOST_USER=noreply@lootlink.ru
# EMAIL_HOST_PASSWORD=пароль-приложения
# DEFAULT_FROM_EMAIL=noreply@lootlink.ru

# AWS S3 (опционально, для production)
# USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=eu-central-1

# Sentry (мониторинг ошибок, обязательно для production)
# 1. Зарегистрируйтесь на https://sentry.io (бесплатно до 5K ошибок/мес)
# 2. Создайте проект: Projects → Create Project → Django
# 3. Скопируйте DSN из Settings → Client Keys (DSN)
SENTRY_DSN=
ENVIRONMENT=production
RELEASE_VERSION=1.0.0

# Security (production only)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# Telegram Bot (опционально)
# TELEGRAM_BOT_TOKEN=

# Web Push Notifications (опционально)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_ADMIN_EMAIL=admin@lootlink.ru
