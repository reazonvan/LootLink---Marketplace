    # Replace with your production email for Let's Encrypt notices.
    email ivanpetrov20066.ip@gmail.com
    # Use Let's Encrypt explicitly to avoid fallback noise from other CAs.
    acme_ca https://acme-v02.api.letsencrypt.org/directory
}

www.lootlink.ru {
    # Preserve request method/body for non-GET requests (e.g. login POST)
    redir https://lootlink.ru{uri} 308
}

lootlink.ru {
    encode zstd gzip

    # Block sensitive paths — return 403 regardless of backend state
    @sensitive path /.env* /.git* /.docker* /docker-compose* /.planning* /manage.py
    respond @sensitive 403

    # Canonical SEO files from collected static
    @robots path /robots.txt
    handle @robots {
        root * /srv/static
        file_server
    }

    @manifest path /manifest.json
    handle @manifest {
        root * /srv/static
        file_server
    }

    # Serve collected static and uploaded media directly from Caddy.
    @static path /static/*
    handle @static {
        header Cache-Control "public, max-age=2592000, immutable"
        root * /srv
        file_server
    }

    @media path /media/*
    handle @media {
        header Cache-Control "public, max-age=86400"
        root * /srv
        file_server
    }

    # Flower Celery monitoring (basic auth via Flower itself)
    @flower path /flower /flower/*
    handle @flower {
        uri strip_prefix /flower
        reverse_proxy flower:5555
    }

    reverse_proxy web:8000 {
        lb_try_duration 5s
        lb_try_interval 250ms
        fail_duration 10s
    }
}

# Redirect plain HTTP access by server IP to canonical domain.
http://91.218.246.114 {
    redir https://lootlink.ru{uri} 301
}
