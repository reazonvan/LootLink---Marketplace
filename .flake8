[flake8]
max-line-length = 100
exclude =
    .git,
    __pycache__,
    */migrations/*,
    .venv,
    .venv-local,
    .venv-codex,
    .venv-dev,
    venv/,
    env/,
    .tox/,
    build/,
    dist/,
    .eggs/,
    *.egg-info/,
    logs/,
    scripts/,
    tests/locust/,
    docs/ПП01,
    docs/ПП02

# E203 — whitespace before ':' (конфликт с black/PEP8)
# E501 — line too long (оставлено на усмотрение black)
# W291 / W293 — пробелы в конце строки (их приводит black)
# W391 — пустая строка в конце файла (косметика)
# W503 / W504 — перенос до/после бинарного оператора (несовместимые правила)
# F401 — импорт не используется (типично для Django __init__.py)
# F841 — локальная переменная не используется (часто допустимо для читаемости)
ignore =
    E203,
    E501,
    W291,
    W293,
    W391,
    W503,
    W504,
    F401,
    F841

per-file-ignores =
    __init__.py:F401
    settings.py:E501
    # Тесты часто используют 'l' для listing/loop, C901 для сложных fixture-сценариев
    test_*.py:E741,C901
    tests_*.py:E741,C901
    tests.py:E741,C901

# max-complexity=15 — реалистично для Django views с branching по статусу/permissions.
# Конкретные сложные функции помечать noqa: C901 с комментарием почему.
max-complexity = 15
